      },
      {
        "name": "Low-patience",
        "description": "Needs good recommendations quickly and loses utility faster when sequences feel stale."
      }
    ],
    "purpose": "Compare a baseline and candidate recommender in one reproducible run and surface hidden tradeoffs before launch."
