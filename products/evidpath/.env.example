# Copy the values you need into a local `.env`, `~/.evidpath.env`, or your
# shell environment. Evidpath reads existing environment variables first and
# will not overwrite them from a dotenv file.

OPENAI_API_KEY=your-openai-api-key

# Optional provider override. Leave unset to use the default OpenAI Responses
# endpoint at https://api.openai.com/v1/responses.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional shared request controls.
# OPENAI_TIMEOUT_SECONDS=45
# OPENAI_RETRY_COUNT=1

# Optional purpose-specific request controls.
# OPENAI_SCENARIO_TIMEOUT_SECONDS=45
# OPENAI_SCENARIO_RETRY_COUNT=1
# OPENAI_POPULATION_TIMEOUT_SECONDS=45
# OPENAI_POPULATION_RETRY_COUNT=1
# OPENAI_SEMANTIC_TIMEOUT_SECONDS=45
# OPENAI_SEMANTIC_RETRY_COUNT=1
# OPENAI_PLANNER_TIMEOUT_SECONDS=45
# OPENAI_PLANNER_RETRY_COUNT=1
